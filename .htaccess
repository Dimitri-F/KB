# Désactiver le listage des dossiers
Options -Indexes

# Page d'accueil
DirectoryIndex index.html index.php

# Forcer HTTPS
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} !=on
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Protection du fichier .env
<Files ".env">
    Require all denied
</Files>

# Protection des fichiers Composer
<FilesMatch "^composer\.(json|lock)$">
    Require all denied
</FilesMatch>

# Protection des fichiers cachés (.git, etc.)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>